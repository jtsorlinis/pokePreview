{
  "name": "pokemon-champions-advisor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://jtsorlinis.github.io/pokePreview/",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "build:pages": "tsc --noEmit -p tsconfig.json && vite build --base=${GITHUB_PAGES_BASE:-/pokePreview/}",
    "predeploy": "npm run build:pages",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch:data": "tsx scripts/fetch-data.ts && tsx scripts/build-move-options.ts && tsx scripts/fetch-meta.ts",
    "build:move-options": "tsx scripts/build-move-options.ts",
    "fetch:meta": "tsx scripts/fetch-meta.ts"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cheerio": "^1.0.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
